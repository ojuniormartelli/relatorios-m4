# Google Ads API
# Como conseguir: https://developers.google.com/google-ads/api/docs/oauth/overview
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# ID da conta MCC (gerente) - obrigatório se usar conta gerente
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta Ads API (Facebook Marketing API)
# Token: https://developers.facebook.com/docs/marketing-api/access
META_ADS_TOKEN=
META_ADS_ACCOUNT_ID=

# Google Sheets (opcional - fallback)
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_ID=
